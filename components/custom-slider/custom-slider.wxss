.slider-shell {
  position: relative;
  height: 76rpx;
  display: flex;
  align-items: center;
}

.slider-track {
  position: relative;
  width: 100%;
  height: 28rpx;
  border-radius: 999rpx;
  background: #eef1f5;
  overflow: hidden;
}

.slider-progress {
  height: 100%;
  border-radius: 999rpx;
  transition: width 0.08s linear;
}

.slider-thumb {
  position: absolute;
  top: 10rpx;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: #ffffff;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.18);
  transition: left 0.08s linear;
}
