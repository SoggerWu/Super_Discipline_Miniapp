page {
  min-height: 100vh;
  background: #f6f7f9;
  color: #101820;
}

.profile-page {
  padding: 20rpx 20rpx 180rpx;
}

.profile-card,
.profile-list,
.tab-bar {
  background: #ffffff;
  border-radius: 28rpx;
  border: 1rpx solid rgba(16, 24, 32, 0.06);
}

.profile-card {
  padding: 28rpx 24rpx;
}

.profile-name {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
}

.profile-meta {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #6b7b90;
}

.profile-list {
  margin-top: 16rpx;
  padding: 8rpx 0;
}

.profile-item {
  padding: 24rpx;
  font-size: 26rpx;
  border-bottom: 1rpx solid #eef2f6;
}

.profile-item:last-child {
  border-bottom: none;
}

.tab-bar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
  padding: 10rpx;
}

.tab-item {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
}

.tab-item-active {
  background: #101820;
}

.tab-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #101820;
}

.tab-item-active .tab-label {
  color: #ffffff;
}
