page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7fafd 0%, #f4f7fb 100%);
  color: #101820;
}

.history-page {
  position: relative;
  padding: 20rpx 20rpx 170rpx;
}

.history-topbar {
  margin-bottom: 16rpx;
}

.history-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
  color: #15293d;
}

.history-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #73859b;
}

.calendar-shell {
  background: rgba(255, 255, 255, 0.94);
  border-radius: 30rpx;
  border: 1rpx solid rgba(16, 24, 32, 0.05);
  box-shadow: 0 12rpx 28rpx rgba(71, 88, 110, 0.06);
  padding: 20rpx 14rpx 18rpx;
}

.calendar-head {
  margin-bottom: 14rpx;
}

.month-header {
  display: flex;
  justify-content: center;
  align-items: center;
}

.month-switch {
  width: 60rpx;
  height: 52rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #f2f5f8;
}

.month-chevron {
  width: 16rpx;
  height: 16rpx;
  border-top: 4rpx solid #60778f;
  border-right: 4rpx solid #60778f;
  box-sizing: border-box;
}

.month-chevron-left {
  transform: rotate(-135deg);
  margin-left: 8rpx;
}

.month-chevron-right {
  transform: rotate(45deg);
  margin-right: 8rpx;
}

.month-label {
  min-width: 220rpx;
  margin: 0 12rpx;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 52rpx;
  text-align: center;
  color: #15293d;
}

.weekdays,
.days-grid {
  display: flex;
  flex-wrap: wrap;
}

.weekday,
.day-cell {
  box-sizing: border-box;
  text-align: center;
}

.weekday {
  padding: 10rpx 0 12rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #8a97aa;
  background: transparent;
}

.day-cell {
  min-height: 148rpx;
  padding: 8rpx 0 10rpx;
  border-right: 1rpx solid #e8edf2;
  border-bottom: 1rpx solid #e8edf2;
  background: rgba(255, 255, 255, 0.96);
}

.day-cell-tappable:active {
  background: rgba(232, 239, 247, 0.9);
}

.day-cell-weekend {
  background: #f7fafc;
}

.day-cell:nth-child(5n + 1) {
  border-left: 1rpx solid #e8edf2;
}

.day-num {
  display: block;
  margin-top: 2rpx;
  font-size: 20rpx;
  font-weight: 600;
  color: #5d7087;
}

.history-ring-canvas {
  width: 108rpx;
  height: 108rpx;
  margin: 6rpx auto 0;
}

.weekend-toggle {
  position: fixed;
  right: -18rpx;
  z-index: 8;
  width: 68rpx;
  height: 122rpx;
  border-top-left-radius: 999rpx;
  border-bottom-left-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(16, 24, 32, 0.05);
  box-shadow: 0 10rpx 24rpx rgba(70, 86, 106, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(16rpx);
}

.weekend-toggle-active {
  right: -4rpx;
  background: rgba(238, 245, 255, 0.88);
}

.weekend-toggle-pill {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: 100%;
  height: 100%;
}

.weekend-toggle-arrow {
  font-size: 24rpx;
  line-height: 1;
  color: #6c8095;
}

.weekend-toggle-grip {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.weekend-toggle-dot {
  width: 7rpx;
  height: 7rpx;
  border-radius: 50%;
  background: #b6c3d0;
}

.weekend-toggle-active .weekend-toggle-dot {
  background: #7aaeff;
}

.weekend-toggle-active .weekend-toggle-arrow {
  color: #4b85df;
}

.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  height: 118rpx;
  padding: 14rpx 28rpx 0;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid rgba(16, 24, 32, 0.08);
  box-sizing: border-box;
}

.tab-item {
  width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #8b929d;
}

.tab-item-active {
  color: #46b56f;
}

.tab-icon {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 6rpx;
}

.tab-label {
  font-size: 21rpx;
  line-height: 1;
  color: inherit;
}

.tab-home-roof {
  position: absolute;
  left: 10rpx;
  top: 5rpx;
  width: 20rpx;
  height: 20rpx;
  border-top: 4rpx solid currentColor;
  border-left: 4rpx solid currentColor;
  transform: rotate(45deg);
  border-top-left-radius: 4rpx;
}

.tab-home-body {
  position: absolute;
  left: 8rpx;
  bottom: 4rpx;
  width: 24rpx;
  height: 17rpx;
  border: 4rpx solid currentColor;
  border-top: none;
  border-bottom-left-radius: 7rpx;
  border-bottom-right-radius: 7rpx;
  box-sizing: border-box;
}

.tab-record-bar {
  position: absolute;
  bottom: 4rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.tab-record-bar-1 {
  left: 5rpx;
  height: 16rpx;
}

.tab-record-bar-2 {
  left: 14rpx;
  height: 26rpx;
}

.tab-record-bar-3 {
  left: 23rpx;
  height: 20rpx;
}

.tab-record-bar-4 {
  left: 32rpx;
  height: 31rpx;
}

.tab-profile-head {
  position: absolute;
  left: 12rpx;
  top: 3rpx;
  width: 17rpx;
  height: 17rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.tab-profile-body {
  position: absolute;
  left: 5rpx;
  bottom: 4rpx;
  width: 30rpx;
  height: 14rpx;
  border: 4rpx solid currentColor;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  border-bottom: none;
  box-sizing: border-box;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  background: rgba(15, 23, 42, 0.28);
}

.detail-modal {
  position: fixed;
  left: 42rpx;
  right: 42rpx;
  top: 190rpx;
  bottom: 190rpx;
  z-index: 21;
  display: flex;
  flex-direction: column;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.985);
  box-shadow: 0 24rpx 60rpx rgba(55, 72, 93, 0.16);
  overflow: hidden;
}

.detail-modal-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 24rpx 24rpx 18rpx;
  border-bottom: 1rpx solid rgba(16, 24, 32, 0.06);
}

.detail-modal-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #14283d;
}

.detail-modal-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6e8298;
}

.detail-modal-head-right {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.detail-modal-score {
  font-size: 40rpx;
  font-weight: 700;
  color: #17324b;
  letter-spacing: -1rpx;
}

.detail-close {
  width: 54rpx;
  height: 54rpx;
  border-radius: 50%;
  background: #f2f5f8;
  display: flex;
  align-items: center;
  justify-content: center;
}

.detail-close-line {
  position: absolute;
  width: 26rpx;
  height: 3rpx;
  border-radius: 999rpx;
  background: #72869b;
}

.detail-close-line-a {
  transform: rotate(45deg);
}

.detail-close-line-b {
  transform: rotate(-45deg);
}

.detail-modal-body {
  flex: 1;
  padding: 20rpx 24rpx 24rpx;
  box-sizing: border-box;
}

.detail-status-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 112rpx;
  height: 50rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #eef3f8;
  font-size: 22rpx;
  font-weight: 600;
  color: #5d748c;
}

.detail-rings-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 22rpx;
}

.detail-metric-card {
  padding: 22rpx 18rpx;
  border-radius: 24rpx;
  background: #f4f7fa;
}

.detail-metric-name {
  display: block;
  font-size: 22rpx;
  color: #6d8096;
}

.detail-metric-score {
  display: block;
  margin-top: 12rpx;
  font-size: 34rpx;
  font-weight: 700;
}

.detail-feedback-card,
.detail-photo-card {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: #f4f7fa;
}

.detail-card-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #18314a;
}

.detail-feedback-copy {
  display: block;
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #395067;
}

.detail-photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.detail-photo-image {
  width: 118rpx;
  height: 118rpx;
  border-radius: 18rpx;
}

.detail-photo-empty {
  display: block;
  margin-top: 14rpx;
  font-size: 22rpx;
  color: #7d90a5;
}
