page {
  min-height: 100vh;
  background: #f6f7f9;
  color: #101820;
}

.history-page {
  padding: 20rpx 20rpx 180rpx;
}

.history-head {
  margin-bottom: 18rpx;
}

.history-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
}

.history-subtitle {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6c7b90;
}

.calendar-card,
.tab-bar {
  background: #ffffff;
  border-radius: 28rpx;
  border: 1rpx solid rgba(16, 24, 32, 0.06);
}

.calendar-card {
  display: flex;
  flex-wrap: wrap;
  padding: 18rpx 14rpx 12rpx;
}

.weekday,
.day-cell {
  width: 20%;
  box-sizing: border-box;
  text-align: center;
}

.weekday {
  padding: 8rpx 0 14rpx;
  font-size: 20rpx;
  color: #8391a5;
}

.day-cell {
  min-height: 152rpx;
  padding: 10rpx 0 12rpx;
  border-radius: 20rpx;
}

.day-num {
  display: block;
  font-size: 20rpx;
}

.history-ring-canvas {
  width: 84rpx;
  height: 84rpx;
  margin: 16rpx auto 0;
}

.tab-bar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
  padding: 10rpx;
}

.tab-item {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
}

.tab-item-active {
  background: #101820;
}

.tab-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #101820;
}

.tab-item-active .tab-label {
  color: #ffffff;
}
