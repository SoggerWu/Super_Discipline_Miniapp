page {
  min-height: 100vh;
  background: linear-gradient(180deg, #f7fafc 0%, #f2f6fa 100%);
  color: #101820;
}

.parent-page {
  padding: 20rpx 20rpx 170rpx;
}

.hero-panel,
.content-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 32rpx;
  border: 1rpx solid rgba(16, 24, 32, 0.05);
  box-shadow: 0 12rpx 28rpx rgba(71, 88, 110, 0.06);
}

.hero-panel {
  padding: 26rpx 20rpx 24rpx;
}

.hero-student {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.hero-class {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6a788a;
}

.ring-stage {
  position: relative;
  width: 520rpx;
  height: 520rpx;
  margin: 24rpx auto 20rpx;
}

.ring-shell {
  position: absolute;
  left: 16rpx;
  top: 16rpx;
  width: 488rpx;
  height: 488rpx;
  border-radius: 50%;
  background: #0a2b39;
  box-shadow: 0 14rpx 32rpx rgba(4, 15, 23, 0.18);
}

.ring-canvas {
  position: relative;
  z-index: 2;
  width: 520rpx;
  height: 520rpx;
}

.ring-center {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 124rpx;
  height: 124rpx;
  margin-left: -62rpx;
  margin-top: -62rpx;
  border-radius: 50%;
  background: #0a2b39;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
}

.ring-score {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 700;
  color: #f4fbff;
  letter-spacing: -0.8rpx;
}

.legend-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10rpx;
  margin-top: -4rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f3f6f9;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 8rpx;
  border-radius: 50%;
}

.legend-label {
  font-size: 20rpx;
  color: #516278;
}

.legend-value {
  margin-left: 10rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #101820;
}

.content-card {
  margin-top: 16rpx;
  padding: 22rpx 20rpx;
}

.card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
}

.card-copy {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #4c5d73;
}

.photo-chip-row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.photo-chip {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f1f5f9;
  font-size: 22rpx;
  color: #516278;
}

.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 10;
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  height: 118rpx;
  padding: 14rpx 28rpx 0;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid rgba(16, 24, 32, 0.08);
  box-sizing: border-box;
}

.tab-item {
  width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #8b929d;
}

.tab-item-active {
  color: #46b56f;
}

.tab-icon {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 6rpx;
}

.tab-label {
  font-size: 21rpx;
  line-height: 1;
  color: inherit;
}

.tab-home-roof {
  position: absolute;
  left: 10rpx;
  top: 5rpx;
  width: 20rpx;
  height: 20rpx;
  border-top: 4rpx solid currentColor;
  border-left: 4rpx solid currentColor;
  transform: rotate(45deg);
  border-top-left-radius: 4rpx;
}

.tab-home-body {
  position: absolute;
  left: 8rpx;
  bottom: 4rpx;
  width: 24rpx;
  height: 17rpx;
  border: 4rpx solid currentColor;
  border-top: none;
  border-bottom-left-radius: 7rpx;
  border-bottom-right-radius: 7rpx;
  box-sizing: border-box;
}

.tab-record-bar {
  position: absolute;
  bottom: 4rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.tab-record-bar-1 {
  left: 5rpx;
  height: 16rpx;
}

.tab-record-bar-2 {
  left: 14rpx;
  height: 26rpx;
}

.tab-record-bar-3 {
  left: 23rpx;
  height: 20rpx;
}

.tab-record-bar-4 {
  left: 32rpx;
  height: 31rpx;
}

.tab-profile-head {
  position: absolute;
  left: 12rpx;
  top: 3rpx;
  width: 17rpx;
  height: 17rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.tab-profile-body {
  position: absolute;
  left: 5rpx;
  bottom: 4rpx;
  width: 30rpx;
  height: 14rpx;
  border: 4rpx solid currentColor;
  border-top-left-radius: 20rpx;
  border-top-right-radius: 20rpx;
  border-bottom: none;
  box-sizing: border-box;
}
