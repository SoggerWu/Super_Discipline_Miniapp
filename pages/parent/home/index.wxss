page {
  min-height: 100vh;
  background: #f4f6f8;
  color: #101820;
}

.parent-page {
  padding: 20rpx 20rpx 180rpx;
}

.hero-panel,
.content-card,
.tab-bar {
  background: #ffffff;
  border-radius: 30rpx;
  border: 1rpx solid rgba(16, 24, 32, 0.06);
}

.hero-panel {
  padding: 24rpx 18rpx 22rpx;
}

.hero-student {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.hero-class {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #6a788a;
}

.ring-stage {
  position: relative;
  width: 520rpx;
  height: 520rpx;
  margin: 24rpx auto 20rpx;
}

.ring-shell {
  position: absolute;
  left: 16rpx;
  top: 16rpx;
  width: 488rpx;
  height: 488rpx;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 28%, #fbfdfe 0%, #f2f7fa 52%, #e5eef3 100%);
  box-shadow: 0 16rpx 40rpx rgba(91, 118, 140, 0.12);
}

.ring-canvas {
  position: relative;
  z-index: 2;
  width: 520rpx;
  height: 520rpx;
}

.ring-center {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 124rpx;
  height: 124rpx;
  margin-left: -62rpx;
  margin-top: -62rpx;
  border-radius: 50%;
  background: #edf3f6;
  box-shadow: inset 0 0 0 1rpx rgba(135, 157, 175, 0.16);
}

.ring-score {
  font-size: 34rpx;
  line-height: 1;
  font-weight: 700;
  color: #1b3441;
  letter-spacing: -0.8rpx;
}

.legend-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 10rpx;
  margin-top: -4rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #f0f3f7;
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  margin-right: 8rpx;
  border-radius: 50%;
}

.legend-label {
  font-size: 20rpx;
  color: #516278;
}

.legend-value {
  margin-left: 10rpx;
  font-size: 20rpx;
  font-weight: 700;
  color: #101820;
}

.content-card {
  margin-top: 16rpx;
  padding: 22rpx 20rpx;
}

.card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
}

.card-copy {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #4c5d73;
}

.photo-chip-row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.photo-chip {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #eef3f8;
  font-size: 22rpx;
  color: #516278;
}

.tab-bar {
  position: fixed;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
  display: flex;
  padding: 10rpx;
}

.tab-item {
  flex: 1;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
}

.tab-item-active {
  background: #101820;
}

.tab-label {
  font-size: 24rpx;
  line-height: 1;
  font-weight: 600;
  color: #101820;
}

.tab-item-active .tab-label {
  color: #ffffff;
}
