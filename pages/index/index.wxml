<navigation-bar
  title="晚自习评分"
  back="{{false}}"
  color="white"
  background="transparent"
></navigation-bar>

<view class="page-shell">
  <view wx:if="{{currentTab === 'score'}}" class="page-body score-page">
    <view class="section-block student-panel">
      <view class="section-head">
        <text class="section-title">学生</text>
        <text class="section-meta">{{students.length}} 人</text>
      </view>
      <scroll-view class="student-scroll" scroll-x enhanced show-scrollbar="{{false}}">
        <view class="student-row">
          <view
            wx:for="{{students}}"
            wx:key="id"
            class="student-chip {{item.id === activeStudent.id ? 'student-chip-active' : ''}}"
            data-id="{{item.id}}"
            bindtap="handleStudentChange"
          >
            <text class="student-name">{{item.name}}</text>
            <text class="student-group">{{item.group}}</text>
          </view>
        </view>
      </scroll-view>
    </view>

    <view class="hero-head">
      <text class="hero-kicker">Evening Study</text>
      <text class="hero-title">{{activeStudent.name}}</text>
      <text class="hero-subtitle">{{activeStudent.group}} · 行为评分</text>
    </view>

    <view class="ring-stage">
      <view class="ring-shadow"></view>
      <view class="ring-orb"></view>
      <view class="ring-glass"></view>
      <canvas
        type="2d"
        id="scoreRings"
        canvas-id="scoreRings"
        class="ring-canvas"
      ></canvas>
      <view class="ring-overlay">
        <text class="ring-score">{{summaryScore}}</text>
      </view>
    </view>

    <view class="ring-legend">
      <view wx:for="{{metrics}}" wx:key="key" class="legend-pill">
        <text class="legend-dot" style="background: {{item.color}};"></text>
        <text class="legend-label">{{item.label}}</text>
        <text class="legend-value">{{item.score}}</text>
      </view>
    </view>

    <view class="section-block sliders-card">
      <view class="section-head">
        <text class="section-title">滑动评分</text>
        <text class="section-meta">0 - 100 分</text>
      </view>

      <view wx:for="{{metrics}}" wx:key="key" class="slider-item">
        <view class="slider-head">
          <view>
            <text class="slider-title">{{item.label}}</text>
            <text class="slider-desc">{{item.description}}</text>
          </view>
          <text class="slider-score">{{item.score}}</text>
        </view>
        <slider
          class="score-slider"
          min="0"
          max="100"
          step="1"
          value="{{item.score}}"
          activeColor="{{item.color}}"
          backgroundColor="rgba(255,255,255,0.08)"
          block-color="{{item.color}}"
          block-size="18"
          data-key="{{item.key}}"
          bindchanging="handleSliderChange"
          bindchange="handleSliderChange"
        />
      </view>

      <view class="save-panel">
        <view class="save-copy">
          <text class="save-title">{{currentDate}} 晚自习</text>
          <text class="save-desc">将当前学生评分写入日历记录</text>
        </view>
        <button class="save-button" bindtap="handleSaveRecord">{{saveButtonText}}</button>
      </view>
    </view>
  </view>

  <view wx:if="{{currentTab === 'calendar'}}" class="page-body calendar-page">
    <view class="calendar-head">
      <view class="calendar-topline">
        <view class="calendar-month-pill">
          <button class="month-switch month-switch-left" data-offset="-1" bindtap="handleMonthChange">‹</button>
          <text class="calendar-title">{{viewedMonthTitle}}</text>
          <button class="month-switch month-switch-right" data-offset="1" bindtap="handleMonthChange">›</button>
        </view>
        <view class="calendar-actions">
          <view class="weekend-toggle" bindtap="handleWeekendToggle">
            {{showWeekend ? '隐藏周末' : '显示周末'}}
          </view>
        </view>
      </view>
      <view class="calendar-stats-row">
        <view class="calendar-student-wrap">
          <text class="calendar-student-name">{{activeStudent.name}}</text>
        </view>
        <view class="calendar-stats-wrap">
          <text class="calendar-stat-text">已评 {{calendarStats.scoredDays}} 天</text>
          <text class="calendar-stat-dot">·</text>
          <text class="calendar-stat-text">均分 {{calendarStats.average}}</text>
        </view>
      </view>
    </view>

    <scroll-view class="calendar-student-scroll" scroll-x enhanced show-scrollbar="{{false}}">
      <view class="student-row">
        <view
          wx:for="{{students}}"
          wx:key="id"
          class="student-chip calendar-student-chip {{item.id === activeStudent.id ? 'student-chip-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="handleStudentChange"
        >
          <text class="student-name">{{item.name}}</text>
        </view>
      </view>
    </scroll-view>

    <view class="calendar-grid">
      <view
        wx:for="{{calendarWeekdayLabels}}"
        wx:key="*this"
        class="weekday-cell"
        style="width: {{showWeekend ? '14.285%' : '20%'}};"
      >
        {{item}}
      </view>

      <view
        wx:for="{{calendarDays}}"
        wx:key="id"
        class="calendar-cell {{item.placeholder ? 'calendar-cell-placeholder' : ''}} {{item.date === selectedCalendarDate ? 'calendar-cell-active' : ''}}"
        data-date="{{item.date}}"
        style="width: {{item.cellWidth}};"
        bindtap="handleCalendarSelect"
      >
          <block wx:if="{{!item.placeholder}}">
            <text class="calendar-day {{item.today ? 'calendar-day-today' : ''}}">{{item.day}}</text>
            <canvas
              type="2d"
              class="calendar-ring-canvas"
              canvas-id="{{item.canvasId}}"
            ></canvas>
          </block>
        </view>
      </view>
  </view>

  <view class="bottom-nav">
    <view
      wx:for="{{tabBar}}"
      wx:key="key"
      class="nav-item {{item.key === currentTab ? 'nav-item-active' : ''}}"
      data-key="{{item.key}}"
      bindtap="handleTabChange"
    >
      <text class="nav-label">{{item.label}}</text>
    </view>
  </view>

  <view wx:if="{{isCalendarEditorOpen}}" class="editor-mask" bindtap="handleCalendarEditorClose"></view>
  <view wx:if="{{isCalendarEditorOpen}}" class="editor-sheet">
    <view class="editor-head">
      <view>
        <text class="editor-title">{{calendarEditor.date}} 晚自习</text>
        <text class="editor-subtitle">{{activeStudent.name}} · 综合 {{calendarEditor.average}}</text>
      </view>
      <view class="editor-close" bindtap="handleCalendarEditorClose">关闭</view>
    </view>

    <view wx:for="{{metrics}}" wx:key="key" class="editor-item">
      <view class="slider-head">
        <view>
          <text class="slider-title">{{item.label}}</text>
          <text class="slider-desc">{{item.description}}</text>
        </view>
        <text class="slider-score">{{calendarEditor.scores[item.key]}}</text>
      </view>
      <slider
        class="score-slider"
        min="0"
        max="100"
        step="1"
        value="{{calendarEditor.scores[item.key]}}"
        activeColor="{{item.color}}"
        backgroundColor="rgba(255,255,255,0.08)"
        block-color="{{item.color}}"
        block-size="18"
        data-key="{{item.key}}"
        bindchanging="handleCalendarEditorChange"
        bindchange="handleCalendarEditorChange"
      />
    </view>

    <button class="editor-save-button" bindtap="handleCalendarEditorSave">保存本日评分</button>
  </view>
</view>
