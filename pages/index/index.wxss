page {
  min-height: 100vh;
  background: linear-gradient(180deg, #0e1520, #091017);
  color: #f3f6fb;
}

.gateway-page {
  padding: 28rpx 24rpx 40rpx;
}

.gateway-head {
  margin-bottom: 28rpx;
}

.gateway-kicker {
  display: block;
  font-size: 20rpx;
  letter-spacing: 5rpx;
  text-transform: uppercase;
  color: #8fa4c0;
}

.gateway-title {
  display: block;
  margin-top: 12rpx;
  font-size: 52rpx;
  font-weight: 700;
}

.gateway-subtitle {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #b2bfd3;
}

.gateway-card {
  margin-top: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
}

.gateway-card-tag {
  display: inline-block;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(83, 216, 255, 0.14);
  color: #8ee8ff;
  font-size: 20rpx;
}

.gateway-card-title {
  display: block;
  margin-top: 18rpx;
  font-size: 34rpx;
  font-weight: 600;
}

.gateway-card-copy {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #aab7cb;
}
