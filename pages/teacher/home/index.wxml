<navigation-bar title="超级纪律（教师端）" back="{{true}}" color="black" background="#F3F5F8"></navigation-bar>

<view class="teacher-page">
  <view class="teacher-topbar">
    <view class="teacher-topbar-meta">
      <view class="teacher-class-pill">
        <text class="teacher-class-pill-label">{{classLabel}}</text>
      </view>
      <text class="teacher-date">{{dateLabel}}</text>
    </view>
  </view>

  <view class="teacher-board">
    <view class="student-sidebar">
      <view class="student-sidebar-head">
        <text class="student-sidebar-title">学生</text>
        <view class="student-add-button" bindtap="openStudentModal">
          <text class="student-add-plus">+</text>
        </view>
      </view>

      <scroll-view class="student-sidebar-scroll" scroll-y>
        <view
          wx:for="{{students}}"
          wx:key="id"
          class="student-row {{item.id === activeStudentId ? 'student-row-active' : ''}}"
          data-id="{{item.id}}"
          bindtap="handleStudentChange"
        >
          <view class="student-row-main">
            <text class="student-name">{{item.name}}</text>
          </view>
          <text class="student-dot student-dot-{{item.status}}"></text>
        </view>
      </scroll-view>
    </view>

    <scroll-view class="teacher-main" scroll-y>
      <view wx:if="{{activeStudent}}" class="teacher-panel">
        <view class="teacher-ring-card">
          <view class="teacher-ring-stage">
            <view class="teacher-ring-shell"></view>
            <canvas type="2d" id="teacherRings" canvas-id="teacherRings" class="teacher-ring-canvas"></canvas>
            <view class="teacher-ring-center">
              <text class="teacher-ring-score">{{activeStudent.totalWeighted}}</text>
            </view>
          </view>
          <view class="teacher-ring-footer">
            <text class="teacher-ring-name">{{activeStudent.name}}</text>
            <view class="student-summary-badge status-{{activeStudent.status}}">
              <text class="student-summary-status">{{activeStudent.statusText}}</text>
            </view>
          </view>
        </view>

        <view class="teacher-section">
          <view class="section-head">
            <text class="section-title">评分</text>
          </view>
          <view class="score-card">
            <view wx:for="{{activeStudent.metrics}}" wx:key="key" class="score-row">
              <view class="score-label-row">
                <text class="score-label">{{item.label}}</text>
                <text class="score-value" style="color: {{item.color}};">{{item.scoreText}}</text>
              </view>
              <custom-slider
                value="{{item.score}}"
                max="10"
                activeColor="{{item.color}}"
                data-key="{{item.key}}"
                bind:changing="handleScoreChange"
                bind:change="handleScoreChange"
              ></custom-slider>
            </view>
          </view>
        </view>

        <view class="teacher-section">
          <view class="section-head">
            <text class="section-title">课堂反馈</text>
          </view>
          <view class="feedback-card">
            <textarea
              class="feedback-input"
              maxlength="300"
              placeholder="例如：作业完成认真，背诵状态稳定，课堂纪律良好。"
              value="{{activeStudent.feedback}}"
              bindinput="handleFeedbackInput"
            />
          </view>
        </view>

        <view class="teacher-section">
          <view class="section-head">
            <text class="section-title">作业照片</text>
            <text class="photo-add" bindtap="handlePickImages">上传</text>
          </view>
          <view class="photo-card">
            <view class="photo-list">
              <view wx:for="{{activeStudent.photos}}" wx:key="*this" class="photo-item">
                <image class="photo-image" src="{{item}}" mode="aspectFill"></image>
                <view class="photo-remove" data-index="{{index}}" bindtap="handleRemovePhoto">×</view>
              </view>
              <view wx:if="{{!activeStudent.photos.length}}" class="photo-placeholder">
                <text class="photo-placeholder-title">暂无作业照片</text>
              </view>
            </view>
          </view>
        </view>

        <view class="action-row">
          <button class="primary-btn action-submit-btn" bindtap="handleSubmit">提交给家长</button>
        </view>
      </view>
    </scroll-view>
  </view>

  <view class="teacher-tab-bar">
    <view class="teacher-tab-item teacher-tab-item-active">
      <view class="teacher-tab-icon teacher-tab-icon-home">
        <view class="teacher-tab-home-roof"></view>
        <view class="teacher-tab-home-body"></view>
      </view>
      <text class="teacher-tab-label">首页</text>
    </view>
    <view class="teacher-tab-item" bindtap="goRecord">
      <view class="teacher-tab-icon teacher-tab-icon-record">
        <text class="teacher-tab-record-bar teacher-tab-record-bar-1"></text>
        <text class="teacher-tab-record-bar teacher-tab-record-bar-2"></text>
        <text class="teacher-tab-record-bar teacher-tab-record-bar-3"></text>
        <text class="teacher-tab-record-bar teacher-tab-record-bar-4"></text>
      </view>
      <text class="teacher-tab-label">记录</text>
    </view>
    <view class="teacher-tab-item" bindtap="goProfile">
      <view class="teacher-tab-icon teacher-tab-icon-profile">
        <view class="teacher-tab-profile-head"></view>
        <view class="teacher-tab-profile-body"></view>
      </view>
      <text class="teacher-tab-label">我的</text>
    </view>
  </view>

  <view wx:if="{{showStudentModal}}" class="modal-mask" bindtap="closeModal"></view>

  <view wx:if="{{showStudentModal}}" class="modal-card">
    <text class="modal-title">添加学生</text>
    <input
      class="modal-input"
      placeholder="输入学生姓名"
      value="{{newStudentName}}"
      bindinput="handleStudentNameInput"
    />
    <view class="modal-actions">
      <button class="modal-cancel" bindtap="closeModal">取消</button>
      <button class="modal-confirm" bindtap="handleAddStudent">确定</button>
    </view>
  </view>
</view>
