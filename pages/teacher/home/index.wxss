page {
  height: 100vh;
  overflow: hidden;
  background: linear-gradient(180deg, #f7f9fc 0%, #f5f7fa 100%);
  color: #111827;
}

.teacher-page {
  position: relative;
  height: 100vh;
  overflow: hidden;
  padding: 0 18rpx;
  box-sizing: border-box;
}

.teacher-topbar {
  position: relative;
  z-index: 20;
  margin: 0 -18rpx;
  padding: 16rpx 18rpx 12rpx;
  background: rgba(247, 250, 253, 0.96);
  backdrop-filter: blur(24rpx);
  border-bottom: 1rpx solid rgba(160, 176, 194, 0.16);
}

.teacher-topbar-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.teacher-class-pill {
  display: inline-flex;
  align-items: center;
  height: 50rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #eef3f8;
  border: 1rpx solid rgba(169, 184, 198, 0.18);
}

.teacher-class-pill-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #6d8096;
}

.teacher-date {
  font-size: 22rpx;
  color: #8193a8;
}

.teacher-board {
  display: flex;
  gap: 14rpx;
  height: calc(100vh - 190rpx);
  margin-top: 16rpx;
}

.student-sidebar {
  width: 172rpx;
  height: 100%;
  border-radius: 32rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(122, 145, 170, 0.12);
  box-shadow: 0 12rpx 32rpx rgba(63, 84, 108, 0.06);
  overflow: hidden;
}

.student-sidebar-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 10rpx 14rpx;
}

.student-sidebar-title {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: #6d7f95;
}

.student-add-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 42rpx;
  height: 42rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid rgba(169, 184, 198, 0.2);
  box-shadow: 0 10rpx 24rpx rgba(82, 105, 128, 0.08);
}

.student-add-plus {
  font-size: 28rpx;
  line-height: 1;
  color: #5f7894;
}

.student-sidebar-scroll {
  height: calc(100% - 90rpx);
  padding: 0 6rpx 12rpx;
  box-sizing: border-box;
}

.student-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 72rpx;
  padding: 0 10rpx;
  margin-bottom: 6rpx;
  border-radius: 18rpx;
  box-sizing: border-box;
}

.student-row-active {
  background: linear-gradient(135deg, #eff6ff 0%, #dcecff 100%);
}

.student-row-main {
  min-width: 0;
}

.student-name {
  display: block;
  font-size: 22rpx;
  line-height: 1.2;
  font-weight: 600;
  color: #243548;
}

.student-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.student-dot-idle {
  background: #b8c4d1;
}

.student-dot-draft {
  background: #f1a63b;
}

.student-dot-submitted {
  background: #44c072;
}

.teacher-main {
  flex: 1;
  height: 100%;
  min-width: 0;
  padding-bottom: 156rpx;
  box-sizing: border-box;
}

.teacher-panel {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.teacher-ring-card,
.score-card,
.feedback-card,
.photo-card {
  border-radius: 34rpx;
  background: rgba(255, 255, 255, 0.965);
  border: 1rpx solid rgba(15, 23, 42, 0.05);
  box-shadow: 0 12rpx 30rpx rgba(69, 87, 109, 0.06);
}

.teacher-ring-card {
  padding: 22rpx 22rpx 18rpx;
  box-sizing: border-box;
}

.teacher-ring-stage {
  position: relative;
  width: 312rpx;
  height: 312rpx;
  margin: 0 auto;
}

.teacher-ring-shell {
  position: absolute;
  inset: 8rpx;
  border-radius: 50%;
  background: #0a2b39;
  box-shadow: 0 10rpx 24rpx rgba(4, 15, 23, 0.18);
}

.teacher-ring-canvas {
  position: relative;
  z-index: 2;
  width: 312rpx;
  height: 312rpx;
}

.teacher-ring-center {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 3;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 88rpx;
  height: 88rpx;
  margin-left: -44rpx;
  margin-top: -44rpx;
  border-radius: 50%;
  background: #0a2b39;
  box-shadow: inset 0 0 0 1rpx rgba(255, 255, 255, 0.08);
}

.teacher-ring-score {
  font-size: 28rpx;
  line-height: 1;
  font-weight: 700;
  letter-spacing: -0.6rpx;
  color: #f4fbff;
}

.teacher-ring-footer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 14rpx;
}

.teacher-ring-name {
  font-size: 27rpx;
  font-weight: 700;
  letter-spacing: -0.5rpx;
  color: #172b3f;
}

.student-summary-badge {
  display: inline-flex;
  align-items: center;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
}

.student-summary-status {
  font-size: 18rpx;
  font-weight: 600;
}

.status-idle {
  background: #edf1f5;
  color: #6c7d94;
}

.status-draft {
  background: #fff3df;
  color: #c68421;
}

.status-submitted {
  background: #e6f7ee;
  color: #239655;
}

.teacher-section {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 6rpx;
}

.section-title {
  font-size: 26rpx;
  font-weight: 700;
  letter-spacing: -0.6rpx;
  color: #172b3f;
}

.score-card,
.feedback-card,
.photo-card {
  padding: 20rpx;
  box-sizing: border-box;
}

.score-row + .score-row {
  margin-top: 20rpx;
}

.score-label-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.score-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #172b3f;
}

.score-value {
  min-width: 44rpx;
  text-align: right;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 700;
}

.feedback-input {
  width: 100%;
  min-height: 156rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #f6f9fb;
  font-size: 23rpx;
  line-height: 1.6;
  color: #172b3f;
  box-sizing: border-box;
}

.photo-add {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 76rpx;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #eef4ff;
  color: #2967dd;
  font-size: 19rpx;
  font-weight: 600;
}

.photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.photo-item {
  position: relative;
  width: 148rpx;
  height: 148rpx;
  border-radius: 20rpx;
  overflow: hidden;
}

.photo-image {
  width: 100%;
  height: 100%;
}

.photo-remove {
  position: absolute;
  right: 8rpx;
  top: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.56);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
}

.photo-placeholder {
  width: 100%;
  padding: 28rpx 20rpx;
  border-radius: 22rpx;
  background: #f6f9fb;
  box-sizing: border-box;
}

.photo-placeholder-title {
  display: block;
  font-size: 22rpx;
  font-weight: 600;
  text-align: center;
  color: #8191a7;
}

.action-row {
  display: flex;
  gap: 16rpx;
  padding: 4rpx 0 22rpx;
}

.secondary-btn,
.primary-btn {
  flex: 1;
  height: 82rpx;
  padding: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  line-height: 1;
  font-weight: 600;
}

.secondary-btn {
  color: #304156;
  background: #e8edf4;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(135deg, #2d7cff, #44c072);
}

.secondary-btn::after,
.primary-btn::after {
  border: none;
}

.teacher-tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 18;
  display: flex;
  align-items: flex-start;
  justify-content: space-around;
  height: 118rpx;
  padding: 14rpx 28rpx 0;
  background: rgba(255, 255, 255, 0.98);
  border-top: 1rpx solid rgba(16, 24, 32, 0.08);
  box-sizing: border-box;
}

.teacher-tab-item {
  width: 160rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #8b929d;
}

.teacher-tab-item-active {
  color: #46b56f;
}

.teacher-tab-icon {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 6rpx;
}

.teacher-tab-label {
  font-size: 20rpx;
  line-height: 1;
  color: inherit;
}

.teacher-tab-home-roof {
  position: absolute;
  left: 10rpx;
  top: 5rpx;
  width: 20rpx;
  height: 20rpx;
  border-top: 4rpx solid currentColor;
  border-left: 4rpx solid currentColor;
  transform: rotate(45deg);
  border-top-left-radius: 4rpx;
}

.teacher-tab-home-body {
  position: absolute;
  left: 8rpx;
  bottom: 4rpx;
  width: 24rpx;
  height: 17rpx;
  border: 4rpx solid currentColor;
  border-top: none;
  border-bottom-left-radius: 6rpx;
  border-bottom-right-radius: 6rpx;
  box-sizing: border-box;
}

.teacher-tab-record-bar {
  position: absolute;
  bottom: 4rpx;
  width: 4rpx;
  border-radius: 999rpx;
  background: currentColor;
}

.teacher-tab-record-bar-1 {
  left: 5rpx;
  height: 16rpx;
}

.teacher-tab-record-bar-2 {
  left: 14rpx;
  height: 26rpx;
}

.teacher-tab-record-bar-3 {
  left: 23rpx;
  height: 20rpx;
}

.teacher-tab-record-bar-4 {
  left: 32rpx;
  height: 31rpx;
}

.teacher-tab-profile-head {
  position: absolute;
  left: 12rpx;
  top: 3rpx;
  width: 17rpx;
  height: 17rpx;
  border: 4rpx solid currentColor;
  border-radius: 50%;
  box-sizing: border-box;
}

.teacher-tab-profile-body {
  position: absolute;
  left: 5rpx;
  bottom: 4rpx;
  width: 30rpx;
  height: 14rpx;
  border: 4rpx solid currentColor;
  border-top-left-radius: 18rpx;
  border-top-right-radius: 18rpx;
  border-bottom: none;
  box-sizing: border-box;
}

.modal-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  background: rgba(14, 21, 29, 0.34);
}

.modal-card {
  position: fixed;
  left: 50%;
  top: 50%;
  z-index: 31;
  width: 560rpx;
  padding: 34rpx 28rpx 26rpx;
  border-radius: 30rpx;
  background: #ffffff;
  transform: translate(-50%, -50%);
  box-sizing: border-box;
  box-shadow: 0 22rpx 46rpx rgba(36, 53, 72, 0.16);
}

.modal-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #172b3f;
}

.modal-input {
  height: 88rpx;
  margin-top: 22rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: #f4f7fa;
  font-size: 24rpx;
  color: #172b3f;
}

.modal-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 26rpx;
}

.modal-cancel,
.modal-confirm {
  flex: 1;
  height: 80rpx;
  padding: 0;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
}

.modal-cancel {
  background: #eef3f7;
  color: #5e748d;
}

.modal-confirm {
  background: linear-gradient(135deg, #2d7cff, #4aa4ff);
  color: #ffffff;
}

.modal-cancel::after,
.modal-confirm::after {
  border: none;
}
